{
  "schema_version": 1,
  "experiment_type": "coding_hidden_v2_matrix",
  "experiment_stage": "mechanism_smoke",
  "runner_role": "mechanical_execution_only",
  "timeout_seconds": 7200,
  "immutable_controls": {
    "do_not_change_coco_model": true,
    "target_model_policy": "read-local-default-without-override"
  },
  "out_dir": "runs/coding-hidden-v2-deepseek-targeted-rejection-smoke-v4",
  "command": [
    "python3",
    "work/run_coding_hidden_v2_matrix.py",
    "--out",
    "runs/coding-hidden-v2-deepseek-targeted-rejection-smoke-v4",
    "--seeds",
    "seed-a,seed-b,seed-c",
    "--seed-workers",
    "3",
    "--epochs",
    "2",
    "--rollout-batch-size",
    "1",
    "--reflection-minibatch-size",
    "1",
    "--learning-rate",
    "2",
    "--learning-rate-floor",
    "1",
    "--learning-rate-schedule",
    "constant",
    "--slow-update-sample-size",
    "1",
    "--disable-slow-update",
    "--task-timeout",
    "360",
    "--task-retries",
    "1",
    "--retry-backoff-seconds",
    "5",
    "--validation-confirmation-rounds",
    "0",
    "--validation-required-wins",
    "1",
    "--validation-mean-delta",
    "0.05",
    "--development-gate-required-wins",
    "2",
    "--development-gate-mean-delta",
    "0.05",
    "--early-stop-rejection-limit",
    "0",
    "--editor-timeout",
    "300",
    "--conditions",
    "executive",
    "--train-task-ids",
    "coding-hidden-v2-train-allocation-1,coding-hidden-v2-train-headers-1",
    "--selection-task-ids",
    "coding-hidden-v2-selection-allocation-2,coding-hidden-v2-selection-headers-2",
    "--baseline-summary",
    "runs/coding-hidden-v2-targeted-baseline-v1/summary.json",
    "--resume"
  ],
  "acceptance": {
    "best_baseline_margin": 0.05,
    "min_seed_wins": 2
  },
  "env": {
    "COCO_AGENT_TIMEOUT": "360",
    "EXTERNAL_LLM_BASE_URL": "https://ark-cn-beijing.bytedance.net/api/v3",
    "EXTERNAL_LLM_MODEL": "ep-20260507113406-9h6cz",
    "EXTERNAL_LLM_TIMEOUT": "300"
  },
  "env_passthrough": [
    "EXTERNAL_LLM_API_KEY"
  ]
}
