{
  "acceptance": {
    "best_baseline_margin": 0.05,
    "min_seed_wins": 2
  },
  "command": [
    "python3",
    "work/run_coding_hidden_v2_matrix.py",
    "--out",
    "runs/coding-hidden-v2-deepseek-runner-v1",
    "--seeds",
    "seed-a,seed-b,seed-c",
    "--seed-workers",
    "3",
    "--epochs",
    "2",
    "--rollout-batch-size",
    "10",
    "--reflection-minibatch-size",
    "5",
    "--learning-rate",
    "4",
    "--learning-rate-floor",
    "2",
    "--learning-rate-schedule",
    "cosine",
    "--slow-update-sample-size",
    "3",
    "--task-timeout",
    "360",
    "--task-retries",
    "2",
    "--retry-backoff-seconds",
    "5",
    "--early-stop-rejection-limit",
    "3",
    "--editor-timeout",
    "300",
    "--resume"
