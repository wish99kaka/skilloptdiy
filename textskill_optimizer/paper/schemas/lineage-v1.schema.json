{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://textskill-optimizer.local/schemas/lineage-v1.schema.json",
  "title": "Paper-faithful run lineage v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "claim_class",
    "evidence_level",
    "protocol_id",
    "sources",
    "artifacts",
    "data",
    "models",
    "execution",
    "test_exposure"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["paper-lineage-v1"]},
    "claim_class": {
      "type": "string",
      "enum": [
        "mechanism_test",
        "development_result",
        "contract_aware_extension",
        "paper_faithful_development",
        "paper_faithful_heldout",
        "paper_scale_reproduction"
      ]
    },
    "evidence_level": {
      "type": ["string", "null"],
      "enum": [
        null,
        "paper_mechanism_conformant",
        "fresh_local_efficacy",
        "partial_paper_reproduction",
        "paper_scope_replication"
      ]
    },
    "protocol_id": {"type": "string", "minLength": 1},
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paper_version", "official_reference_commit", "local_code_commit", "upstream_deviation_manifest_sha256"],
      "properties": {
        "paper_version": {"type": "string", "enum": ["2605.23904v2"]},
        "official_reference_commit": {"type": "string", "enum": ["e4ea6a6771e797ef820cdd8bfea64c57e0481065"]},
        "local_code_commit": {"type": "string", "pattern": "[0-9a-f]{40}"},
        "upstream_deviation_manifest_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_sha256", "prompt_sha256", "skill_sha256"],
      "properties": {
        "profile_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"},
        "prompt_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"},
        "skill_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"}
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["split_id", "split_manifest_sha256", "scorer_id", "scorer_sha256", "runner_id", "runner_sha256", "harness_sha256", "environment_sha256"],
      "properties": {
        "split_id": {"type": "string", "minLength": 1},
        "split_manifest_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"},
        "scorer_id": {"type": "string", "minLength": 1},
        "scorer_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"},
        "runner_id": {"type": "string", "minLength": 1},
        "runner_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"},
        "harness_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"},
        "environment_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"}
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "required": ["student_model", "student_reasoning", "optimizer_model", "optimizer_reasoning"],
      "properties": {
        "student_model": {"type": "string", "minLength": 1},
        "student_reasoning": {"type": "string", "minLength": 1},
        "optimizer_model": {"type": "string", "minLength": 1},
        "optimizer_reasoning": {"type": "string", "minLength": 1}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seeds", "retry_policy", "schedule", "provider_versions", "runtime_versions", "optimizer_calls", "optimizer_tokens", "target_calls", "target_tokens", "wall_time_seconds", "cost_scope"],
      "properties": {
        "seeds": {"type": "array", "minItems": 1, "items": {"type": "integer"}},
        "retry_policy": {"type": "string", "minLength": 1},
        "schedule": {"type": "string", "minLength": 1},
        "provider_versions": {"type": "object"},
        "runtime_versions": {"type": "object"},
        "optimizer_calls": {"type": "integer", "minimum": 0},
        "optimizer_tokens": {"type": "integer", "minimum": 0},
        "target_calls": {"type": "integer", "minimum": 0},
        "target_tokens": {"type": "integer", "minimum": 0},
        "wall_time_seconds": {"type": "number", "minimum": 0},
        "cost_scope": {"type": "string", "minLength": 1}
      }
    },
    "test_exposure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "archive_commit", "attempt", "receipt_sha256", "history"],
      "properties": {
        "status": {"type": "string", "enum": ["untouched", "consumed"]},
        "archive_commit": {"type": "string", "pattern": "[0-9a-f]{40}"},
        "attempt": {"type": "integer", "minimum": 0},
        "receipt_sha256": {"type": ["string", "null"], "pattern": "[0-9a-f]{64}"},
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["attempt", "protocol_id", "consumed_at", "receipt_sha256"],
            "properties": {
              "attempt": {"type": "integer", "minimum": 1},
              "protocol_id": {"type": "string", "minLength": 1},
              "consumed_at": {"type": "string", "minLength": 1},
              "receipt_sha256": {"type": "string", "pattern": "[0-9a-f]{64}"}
            }
          }
        }
      }
    }
  }
}
